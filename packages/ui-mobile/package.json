{
  "name": "@sicaho-collab/ui-mobile",
  "version": "1.0.1",
  "description": "Alumable mobile components (React Native + StyleSheet + M3 tokens)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Sicaho-collab/alumable-design-system.git",
    "directory": "packages/ui-mobile"
  },
  "dependencies": {
    "@sicaho-collab/design-tokens": "^1.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "react": "^19.2.0",
    "react-native": "^0.79.0",
    "tsup": "^8.0.0",
    "typescript": "~5.9.3"
  }
}
